.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent conflicts.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if the platform version is different, it may cause errors.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but is often VCSed.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions
pdm.lock
.pdm-plugins/

# PEP 582; project local dependencies [no virtualenv required]
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

